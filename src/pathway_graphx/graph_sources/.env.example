# Neo4j Database Configuration
# Copy this file to .env and update with your actual Neo4j credentials
# Location: Place .env file in project root, src/ directory, or neo4j_network/ directory

# Neo4j connection URI
# Typical formats:
#   bolt://localhost:7687        (local Neo4j)
#   neo4j+s://your.server:7687   (secure connection)
#   neo4j+ssc://your.server:7687 (self-signed certificate)
NEO4J_URI=bolt://localhost:7687

# Neo4j username
# Default for local Neo4j is 'neo4j'
NEO4J_USER=neo4j

# Neo4j password
# Change from default 'password' in production
NEO4J_PASSWORD=password

# Neo4j database name
# Default database is 'neo4j'
# Can be changed if using multiple databases
NEO4J_DATABASE=neo4j

# Enable encryption for Neo4j connection
# Set to 'true' for encrypted connections (SSL/TLS)
# Set to 'false' for unencrypted local development
NEO4J_ENCRYPTED=false
